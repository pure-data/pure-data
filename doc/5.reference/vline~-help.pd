#X text 587 85 Here we first have an immediate jump to 0 and start a new ramp from it to 1 in 0.5 ms., f 23;
#X text 587 147 Note that the ramp up doesn't start at 0 but at the 1st increment step., f 23;
#X obj 159 319 tgl 19 0 empty empty empty 0 -10 0 12 #dfdfdf #000000 #000000 0 1;
#X obj 263 344 samplerate~;
#X floatatom 263 403 12 0 0 0 - - - 0;
#X obj 263 374 expr 1000/$f1;
#X obj 122 383 b;
#X obj 159 400 vline~;
#X obj 159 452 print~;
#X obj 159 364 pack f 10 f;
#X obj 263 317 loadbang;
#X text 253 428 one sample delay;
#X text 443 20 This is more problematic when you try to set a start point to a ramp \, like you can do with [line~]., f 45;
#X text 470 230 Below we deal with this situation by delaying the following ramps after the start point by one sample with [delay]., f 39;
#X obj 223 573 pack f 10;
#X obj 198 617 list;
#X obj 100 540 trigger bang float;
#X obj 100 570 delay 1 1 samp;
#X obj 100 507 tgl 19 0 empty empty empty 0 -10 0 12 #dfdfdf #000000 #000000 0 1;
#X obj 198 660 vline~;
#X text 127 508 Another strategy is to use [delay];
#N canvas 799 303 452 511 sub-sample-accuracy 0;
